# Required
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Upstash REST — lobby state (optional locally, required for Vercel prod)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Upstash TCP — Socket.IO adapter pub/sub (optional locally, recommended for Vercel prod)
UPSTASH_REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# CLI escape hatch for drizzle-kit without full validation
# SKIP_ENV_VALIDATION=true
